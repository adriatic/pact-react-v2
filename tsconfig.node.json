{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "commonjs",
    "moduleResolution": "node",

    "types": ["node"],

    "outDir": "out",
    "rootDir": ".",        

    "strict": true,
    "skipLibCheck": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },

  "include": [
    "host/**/*.ts"
  ]
}