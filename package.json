{
  "name": "pact-react-2",
  "displayName": "PACT",
  "publisher": "adriatic",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pact.setApiKey",
        "title": "PACT: Set GPT Key"
      },
      {
        "command": "pact.setClaudeKey",
        "title": "PACT: Set Claude Key"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:web && npm run build:ext",
    "build:web": "node build-web.js",
    "build:ext": "rm -f out/extension.js && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "openai": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
